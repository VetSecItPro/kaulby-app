#!/usr/bin/env bash
# Pre-commit hook — catches lint / typecheck / secret leaks BEFORE push.
#
# Opt in:   git config core.hooksPath .githooks
# Opt out:  git config --unset core.hooksPath
#
# Why: each failed CI run costs ~3 min of runner time. This hook catches
# the same class of error in <5s locally. Net cost saver across the org.
#
# Skips when the only staged changes are docs/assets — same logic as
# CI's paths-ignore so doc-only commits don't pay for typecheck.

set -e

# Color output if terminal supports it.
if [ -t 1 ]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  RESET='\033[0m'
else
  RED='' ; GREEN='' ; YELLOW='' ; RESET=''
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Detect doc/asset-only commits — same exclude list as CI paths-ignore.
NEEDS_CHECKS=0
while IFS= read -r f; do
  case "$f" in
    *.md|docs/*|.github/runbooks/*) ;;
    public/videos/*|public/*.png|public/*.jpg|public/*.webp|public/*.ico|public/*.svg|public/*.gif|public/*.txt) ;;
    CHANGELOG|LICENSE|.editorconfig|.nvmrc|.npmrc|.gitignore) ;;
    *) NEEDS_CHECKS=1 ;;
  esac
done <<< "$STAGED"

if [ "$NEEDS_CHECKS" -eq 0 ]; then
  printf "${GREEN}✓ Docs/assets only — skipping lint/typecheck${RESET}\n"
  exit 0
fi

# 1. Secret scan on staged content. Mirrors CI's `Secret pattern scan` step
#    so anything CI rejects is also rejected locally — no surprise CI fails.
PATTERNS='sk_live_[a-zA-Z0-9_]{20,}|sk_test_[a-zA-Z0-9_]{20,}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |EC )?PRIVATE KEY|ghp_[a-zA-Z0-9]{36}|glpat-[a-zA-Z0-9\-]{20}'
LEAK=$(git diff --cached -U0 | grep -E "^\+" | grep -E "$PATTERNS" || true)
if [ -n "$LEAK" ]; then
  printf "${RED}✗ Secret pattern detected in staged diff:${RESET}\n"
  echo "$LEAK"
  printf "${YELLOW}If this is a false positive, bypass with: git commit --no-verify${RESET}\n"
  exit 1
fi

# 2. Lint only the staged JS/TS files (fast — full lint takes ~46s).
JS_TS_STAGED=$(echo "$STAGED" | grep -E '\.(ts|tsx|js|jsx)$' || true)
if [ -n "$JS_TS_STAGED" ]; then
  printf "${YELLOW}→ Linting staged files...${RESET}\n"
  if ! pnpm exec eslint --quiet $JS_TS_STAGED 2>&1; then
    printf "${RED}✗ ESLint failed. Fix or bypass with: git commit --no-verify${RESET}\n"
    exit 1
  fi
fi

# 3. Typecheck the whole project. Faster than per-file via tsc;
#    relies on tsbuildinfo cache for incremental.
if [ -n "$JS_TS_STAGED" ]; then
  printf "${YELLOW}→ Typechecking...${RESET}\n"
  if ! pnpm exec tsc --noEmit 2>&1; then
    printf "${RED}✗ Type errors. Fix or bypass with: git commit --no-verify${RESET}\n"
    exit 1
  fi
fi

printf "${GREEN}✓ Pre-commit checks passed${RESET}\n"
exit 0
