{
  "name": "kaulby-app",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:prod": "pnpm build && pnpm start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "backfill:ai-analyzed": "npx tsx scripts/backfill-ai-analyzed.ts",
    "seed:dev-fixture": "export $(grep '^DATABASE_URL' .env.local | xargs) && tsx scripts/seed-dev-fixture.ts",
    "eval:ai": "KAULBY_RUN_AI_EVAL=1 tsx src/__tests__/ai/eval-runner.ts",
    "eval:ai:baseline": "KAULBY_RUN_AI_EVAL=1 tsx src/__tests__/ai/eval-runner.ts --write-baseline",
    "eval:shootout": "KAULBY_RUN_AI_EVAL=1 tsx scripts/eval-shootout.ts",
    "eval:shootout:variance": "KAULBY_RUN_AI_EVAL=1 tsx scripts/eval-shootout.ts --rounds 10 --models flash,pro,haiku",
    "remotion:preview": "cd remotion && npx remotion studio src/index.ts",
    "remotion:render": "cd remotion && npx remotion render src/index.ts ProductDemo ../public/videos/product-demo.mp4 && npx remotion render src/index.ts AIChatDemo ../public/videos/ai-chat-demo.mp4 && npx remotion render src/index.ts ProductDemo ../public/videos/product-demo.webm --codec=vp8 && npx remotion render src/index.ts AIChatDemo ../public/videos/ai-chat-demo.webm --codec=vp8",
    "remotion:posters": "cd remotion && npx remotion still src/index.ts ProductDemo ../public/videos/product-demo-poster.webp --image-format=webp --frame=0 && npx remotion still src/index.ts AIChatDemo ../public/videos/ai-chat-demo-poster.webp --image-format=webp --frame=0"
  },
  "dependencies": {
    "@clerk/nextjs": "6.39.3",
    "@clerk/themes": "2.4.57",
    "@neondatabase/serverless": "1.0.2",
    "@polar-sh/sdk": "0.42.5",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/nextjs": "10.51.0",
    "@serwist/next": "^9.5.7",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.37.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dompurify": "3.4.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "12.38.0",
    "google-play-scraper": "^10.1.2",
    "inngest": "3.54.0",
    "jspdf": "4.2.1",
    "langfuse": "3.38.6",
    "lucide-react": "0.577.0",
    "nanoid": "5.1.7",
    "next": "15.5.15",
    "openai": "6.32.0",
    "posthog-js": "1.363.1",
    "posthog-node": "5.28.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.15.4",
    "resend": "6.9.4",
    "sonner": "2.0.7",
    "svix": "1.89.0",
    "swr": "^2.4.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "ws": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "20.19.30",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "@types/ws": "8.18.1",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.14",
    "postcss": "8.5.12",
    "serwist": "^9.5.8",
    "tailwindcss": "3.4.19",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "~7.3.2",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=9.0.9",
      "rollup": ">=4.59.0",
      "serialize-javascript": ">=7.0.3",
      "esbuild": ">=0.25.0",
      "flatted": ">=3.4.2",
      "protobufjs": ">=7.5.5",
      "lodash": ">=4.17.24",
      "picomatch": ">=4.0.4",
      "uuid": ">=14.0.0",
      "brace-expansion": ">=5.0.5",
      "vite": "~7.3.2",
      "@clerk/shared": ">=3.47.5",
      "postcss": ">=8.5.10"
    }
  }
}
