# =============================================================================
# Kaulby - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your credentials:
#   cp .env.example .env.local
#
# Required variables are marked with (required).
# Optional variables have sensible defaults or enable optional features.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000           # (required) Public URL of the app

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=                                       # (required) Neon connection string

# -----------------------------------------------------------------------------
# Authentication (Clerk)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=                  # (required) Clerk publishable key
CLERK_SECRET_KEY=                                   # (required) Clerk secret key
CLERK_WEBHOOK_SECRET=                               # (required) Clerk webhook signing secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/pricing

# -----------------------------------------------------------------------------
# Payments (Polar.sh)
# -----------------------------------------------------------------------------
POLAR_ACCESS_TOKEN=                                 # (required) Polar API access token
POLAR_WEBHOOK_SECRET=                               # (required) Polar webhook secret
POLAR_ORG_ID=                                       # (required) Polar organization ID
POLAR_PRO_MONTHLY_PRODUCT_ID=                       # (required) Pro monthly product ID
POLAR_PRO_ANNUAL_PRODUCT_ID=                        # (required) Pro annual product ID
POLAR_TEAM_MONTHLY_PRODUCT_ID=                      # (required) Team monthly product ID
POLAR_TEAM_ANNUAL_PRODUCT_ID=                       # (required) Team annual product ID
POLAR_DAY_PASS_PRODUCT_ID=                          # (required) Day pass product ID
POLAR_TEAM_SEAT_MONTHLY_PRODUCT_ID=                 # (required) Extra team seat monthly product ID
POLAR_TEAM_SEAT_ANNUAL_PRODUCT_ID=                  # (required) Extra team seat annual product ID

# -----------------------------------------------------------------------------
# AI / LLM (OpenRouter + Langfuse)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=                                 # (required) OpenRouter API key
LANGFUSE_PUBLIC_KEY=                                # (optional) Langfuse observability public key
LANGFUSE_SECRET_KEY=                                # (optional) Langfuse observability secret key
LANGFUSE_HOST=https://cloud.langfuse.com            # (optional) Langfuse host URL

# -----------------------------------------------------------------------------
# Background Jobs (Inngest)
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=                                  # (required for production) Inngest event key
INNGEST_SIGNING_KEY=                                # (required for production) Inngest signing key

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=                                     # (required) Resend API key

# -----------------------------------------------------------------------------
# Analytics (PostHog)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=                            # (optional) PostHog project API key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # (optional) PostHog ingest host

# -----------------------------------------------------------------------------
# Data Scraping (Apify — only needed for Google Reviews, App Store, Play Store)
# -----------------------------------------------------------------------------
APIFY_API_KEY=                                      # (optional) Apify API key — only for platforms without official APIs

# -----------------------------------------------------------------------------
# Platform API Keys
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=                                    # (required) YouTube Data API v3 key — free at console.cloud.google.com
GITHUB_TOKEN=                                       # (optional) GitHub API token for GitHub monitoring
GITHUB_WEBHOOK_SECRET=                              # (optional) GitHub App webhook secret — required for /api/webhooks/github (COA 4 W2.4)
PRODUCTHUNT_API_KEY=                                # (optional) Product Hunt API key
PRODUCTHUNT_API_SECRET=                             # (optional) Product Hunt API secret
SERPER_API_KEY=                                     # (optional) SerpAPI key for Reddit fallback search
XAI_API_KEY=                                        # (optional) xAI API key for X/Twitter monitoring

# -----------------------------------------------------------------------------
# Caching (Upstash Redis)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=                             # (optional) Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=                           # (optional) Upstash Redis REST token

# -----------------------------------------------------------------------------
# Encryption (required for OAuth token security)
# -----------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Integrations (optional)
# -----------------------------------------------------------------------------

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=

# HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Error Monitoring (Sentry)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=                              # (optional) Sentry DSN (public — safe for client)
SENTRY_AUTH_TOKEN=                                   # (optional) Sentry auth token (build-time source map upload)
SENTRY_ORG=                                          # (optional) Sentry org slug — required for vendor_metrics snapshot cron
SENTRY_PROJECT=                                      # (optional) Sentry project slug — required for vendor_metrics snapshot cron

# -----------------------------------------------------------------------------
# Observability — Vendor Snapshot Cron (Phase 3)
# Used by snapshot-vendor-metrics hourly cron. All optional; missing creds log
# a `_snapshot_failed` row and the rest of the cron continues.
# -----------------------------------------------------------------------------
POSTHOG_PERSONAL_API_KEY=                            # (optional) PostHog personal API key (read access for HogQL)
POSTHOG_PROJECT_ID=                                  # (optional) PostHog project ID (numeric)
VERCEL_TOKEN=                                        # (optional) Vercel API token for deployment status snapshot
VERCEL_TEAM_ID=                                      # (optional) Vercel team ID (use VetSecItPro: team_HFUTBVxI8jKYi334LvgVsVNh)
ADMIN_ALERT_EMAIL=                                   # (optional) Recipient for Phase 5 threshold alerts; if unset, the cron is a no-op

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------
ALLOW_DEV_AUTH_BYPASS=false                         # Set to "true" for local dev auth bypass
